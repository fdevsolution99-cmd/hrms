{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hrms-ctqu.onrender.com/api/:path*"
    }
  ],
  "routes": [
    {
      "src": "^/[^.]+$",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
